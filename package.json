{
  "name": "itworxs-cli",
  "version": "0.29.0",
  "description": "Basis CLI voor ItWorXs projecten",
  "type": "module",
  "bin": {
    "itworxs": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "itworxs"
  ],
  "author": "ItWorXs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2"
  }
}

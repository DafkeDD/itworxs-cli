{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Task",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(chmod -R 777:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./**/.env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "node .claude/scripts/handoff.mjs start" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "node .claude/scripts/handoff.mjs end" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "node .claude/scripts/handoff.mjs end" } ] }
    ]
  }
}
